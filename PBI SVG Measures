--33.
Target Label = 
FORMAT ( [Target_Value], "0.0%" )

--34.
Target_Value = AVERAGE ( 'SVG Sample Data'[Target Value] )

--35.
Variance Colour = 
SWITCH(
    TRUE(),
    ISBLANK([Variance_%]), "#6C757D",
    [Variance_%] > 0, "#2E7D32",
    [Variance_%] < 0, "#C62828",
    "#6C757D"
)

--36.
Variance Direction Symbol = 
SWITCH(
    TRUE(),
    ISBLANK([Variance_%]), "",
    [Variance_%] > 0, "▲",
    [Variance_%] < 0, "▼",
    "●"
)

--37.
Variance Fill Colour = 
SWITCH(
    TRUE(),
    ISBLANK([Variance_%]), "#E9ECEF",
    [Variance_%] > 0, "#D9F2E3",
    [Variance_%] < 0, "#F8D7DA",
    "#E9ECEF"
)

--38.
Variance Label = 
FORMAT ( [Variance_%], "+0.0%;-0.0%;0.0%" )

--39.
Variance_ = [Actual_Value] - [Target_Value]

--40.
Variance_% = 
DIVIDE ( [Variance_], [Target_Value] )

