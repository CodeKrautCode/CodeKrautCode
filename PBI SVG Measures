-25.
SVG Sparkline = 
VAR ChartWidth = 140
VAR ChartHeight = 36
VAR PaddingLeft = 4
VAR PaddingRight = 4
VAR PaddingTop = 4
VAR PaddingBottom = 4
VAR PlotWidth = ChartWidth - PaddingLeft - PaddingRight
VAR PlotHeight = ChartHeight - PaddingTop - PaddingBottom

VAR MinDate =
    CALCULATE (
        MIN ( 'SVG Sample Data'[Date] ),
        ALLSELECTED ( 'SVG Sample Data'[Date] )
    )
VAR MaxDate =
    CALCULATE (
        MAX ( 'SVG Sample Data'[Date] ),
        ALLSELECTED ( 'SVG Sample Data'[Date] )
    )
VAR MinValue = [Sparkline Min Actual]
VAR MaxValue = [Sparkline Max Actual]
VAR ValueRange =
    IF ( MaxValue - MinValue = 0, 0.0001, MaxValue - MinValue )
VAR DateRange =
    IF ( MaxDate = MinDate, 1, MaxDate - MinDate )

VAR SparkTable =
    ADDCOLUMNS (
        SUMMARIZE (
            CALCULATETABLE (
                'SVG Sample Data',
                ALLSELECTED ( 'SVG Sample Data'[Date] )
            ),
            'SVG Sample Data'[Date]
        ),
        "X",
            PaddingLeft
                + DIVIDE ( 'SVG Sample Data'[Date] - MinDate, DateRange ) * PlotWidth,
        "Y",
            PaddingTop
                + ( 1 - DIVIDE (
                    CALCULATE ( AVERAGE ( 'SVG Sample Data'[Actual Value] ) ) - MinValue,
                    ValueRange
                ) ) * PlotHeight
    )

VAR PointList =
    CONCATENATEX (
        SparkTable,
        FORMAT ( [X], "0.0" ) & "," & FORMAT ( [Y], "0.0" ),
        " ",
        'SVG Sample Data'[Date],
        ASC
    )

VAR EndX =
    MAXX ( SparkTable, [X] )
VAR EndY =
    MAXX (
        FILTER ( SparkTable, 'SVG Sample Data'[Date] = MaxDate ),
        [Y]
    )

VAR LineColor = [KPI Colour]

RETURN
    "data:image/svg+xml;utf8," &
    "<svg xmlns='http://www.w3.org/2000/svg' width='" & ChartWidth & "' height='" & ChartHeight & "' viewBox='0 0 " & ChartWidth & " " & ChartHeight & "'>" &
    "<polyline fill='none' stroke='" & LineColor & "' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' points='" & PointList & "'/>" &
    "<circle cx='" & FORMAT ( EndX, "0.0" ) & "' cy='" & FORMAT ( EndY, "0.0" ) & "' r='2.8' fill='" & LineColor & "'/>" &
    "</svg>"

