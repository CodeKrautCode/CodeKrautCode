-- Measures to create an org performance report

--1 Reference Date - this is the basis for all time intelligence in this report, and set to TODAY here.
Reference Date = CALCULATE(MAX(DimDate[Date]), ALL(DimDate))

--2. Active events in time period
Active Alerts =
VAR Ref = [Reference Date] 
RETURN CALCULATE(COUNTROWS(FactActivityLog), 
REMOVEFILTERS(DimDate), DimDate[Date] = Ref, DimActivityType[Category] = "alert")

--3.  Events TODAY in a given category
Admin Events Today = 
VAR Ref = [Reference Date] 
RETURN CALCULATE(COUNTROWS(FactActivityLog), 
REMOVEFILTERS(DimDate), DimDate[Date] = Ref, DimActivityType[Category] = "admin")

--4.  Avg duration of event over total time period, with a pre-existing field for duration
Avg Wait Time = AVERAGE(FactPatientVisit[WaitTimeMinutes])

--5.  Avg duration of event over a specific time period
Avg Wait Time Period = 
VAR S = [Period Start Date] 
VAR E = [Period End Date] 
RETURN CALCULATE([Avg Wait Time], 
REMOVEFILTERS(DimDate), DimDate[Date] >= S && DimDate[Date] <= E)

--6.  Avg duration in a specific month, anchored to a month picker
Avg Wait Time Selected Month = 
VAR Sel = SELECTEDVALUE(MonthPicker[YearMonth]) 
RETURN CALCULATE([Avg Wait Time], 
REMOVEFILTERS(DimDate), DimDate[YearMonth] = Sel)

--7.  Avg rate over total period
Bed Occupancy Rate = DIVIDE(SUM(FactBedOccupancy[BedsOccupied]), SUM(FactBedOccupancy[BedsTotal]))

--8.  Avg Rate over a specific period of time
Bed Occupancy Rate Period = 
VAR S = [Period Start Date] 
VAR E = [Period End Date] 
RETURN CALCULATE([Bed Occupancy Rate], 
REMOVEFILTERS(DimDate), DimDate[Date] >= S && DimDate[Date] <= E)

--9.  Avg Rate in a specific month
Bed Occupancy Selected Month = 
VAR Sel = SELECTEDVALUE(MonthPicker[YearMonth]) 
RETURN CALCULATE([Bed Occupancy Rate], 
REMOVEFILTERS(DimDate), DimDate[YearMonth] = Sel)

--10.  Avg value of a given field
Avg Satisfaction = AVERAGE(FactPatientVisit[SatisfactionScore])

--11.  Rate vs Target - KPI
Bed Occupancy vs Target = [Bed Occupancy Rate Period] - [Target Bed Occupancy]

--12.  FORMATTING for failed KPI
Color Bed Occupancy = IF([Bed Occupancy Rate Period] >= [Target Bed Occupancy], "#16A34A", "#DC2626")

--13.  FORMATTING for failed KPI in a given category
Color Emergency Wait = IF([Emergency Wait Time Period] <= [Target Emergency Wait], "#16A34A", "#DC2626")

--14.  FORMATTING for achieved KPI
Color Satisfaction = IF([Satisfaction Pct Period] >= [Target Satisfaction], "#16A34A", "#DC2626")

--15.  FORMATTING for achieved KPI
Color Staff Efficiency = IF([Staff Efficiency Period] >= [Target Staff Efficiency], "#16A34A", "#DC2626")

--16.  Dynamic Report Subtitle
Dashboard Subtitle = 
"CarePulse Operations / " & SELECTEDVALUE(DimDepartment[DepartmentName], "All Departments") 
      & " / " & SELECTEDVALUE(PeriodPicker[PeriodName], "Today") 
      & " / Ref date: " & FORMAT([Reference Date], "yyyy-mm-dd")

--17.  Duration in a specific category
Emergency Wait Time = 
CALCULATE([Avg Wait Time], FILTER(ALL(DimDepartment), DimDepartment[DepartmentName] = "Emergency"))

---18.  Duration in a specific category over a specific time period
Emergency Wait Time Period = 
VAR S = [Period Start Date] 
VAR E = [Period End Date] 
RETURN CALCULATE([Emergency Wait Time], 
REMOVEFILTERS(DimDate), DimDate[Date] >= S && DimDate[Date] <= E)

--19.  Duration vs Target
Emergency Wait vs Target = [Emergency Wait Time Period] - [Target Emergency Wait]

--20.  Rate for a category
General Ward Occupancy = 
CALCULATE([Bed Occupancy Rate], 
FILTER(ALL(DimRegion), 
DimRegion[RegionName] IN {"General Ward A", "General Ward B"}))

--21.  Availability for a category
ICU Bed Availability = 
VAR Occ = CALCULATE([Bed Occupancy Rate], 
FILTER(ALL(DimRegion), DimRegion[RegionName] = "ICU")) RETURN 1 - Occ

--22.  Define a selected period
Is In Selected Period = 
VAR S = [Period Start Date] 
VAR E = [Period End Date] 
VAR RowDate = MAX(DimDate[Date]) 
RETURN IF(RowDate >= S && RowDate <= E, 1, 0)

--23.  KPI Achievement
KPI Achievement = 
VAR SelKPI = SELECTEDVALUE(KPISelector[KPIName]) 
RETURN SWITCH(SelKPI, "Bed Occupancy", 
            DIVIDE([Bed Occupancy Rate Period], [Target Bed Occupancy]), "Satisfaction", 
            DIVIDE([Satisfaction Pct Period], [Target Satisfaction]), "Staff Efficiency", 
            DIVIDE([Staff Efficiency Period], [Target Staff Efficiency]), "Emergency Wait", 
            DIVIDE([Target Emergency Wait], [Emergency Wait Time Period]),   BLANK())

--24.  Aggregate KPIs Achieved
KPIs On Track = 
VAR BedOK = IF(DIVIDE([Bed Occupancy Rate Period], [Target Bed Occupancy]) >= 1, 1, 0) 
VAR SatOK = IF(DIVIDE([Satisfaction Pct Period], [Target Satisfaction]) >= 1, 1, 0) 
VAR StaffOK = IF(DIVIDE([Staff Efficiency Period], [Target Staff Efficiency]) >= 1, 1, 0) 
VAR EmergOK = IF(DIVIDE([Target Emergency Wait], [Emergency Wait Time Period]) >= 1, 1, 0) 
RETURN BedOK + SatOK + StaffOK + EmergOK

--25.  Occupied/busy rate
Occupied Beds = SUM(FactBedOccupancy[BedsOccupied])

--26.  Events Today
Operations Events Today = 
VAR Ref = [Reference Date] 
RETURN CALCULATE(COUNTROWS(FactActivityLog), 
REMOVEFILTERS(DimDate), DimDate[Date] = Ref, DimActivityType[Category] IN {"operations", "alert"})

--27.  Avg  Achieved Score
Overall Health Score = 
VAR Bed = DIVIDE([Bed Occupancy Rate Period], [Target Bed Occupancy]) 
VAR Sat = DIVIDE([Satisfaction Pct Period], [Target Satisfaction]) 
VAR Staff = DIVIDE([Staff Efficiency Period], [Target Staff Efficiency]) 
VAR Emerg = DIVIDE([Target Emergency Wait], [Emergency Wait Time Period]) 
RETURN DIVIDE(Bed + Sat + Staff + Emerg, 4)

--28.  Activity Volume
Patients Handled = SUM(FactStaffing[PatientsHandled])

--29.  Activity Volume Today
Patients Today = 
VAR Ref = [Reference Date] 
RETURN CALCULATE([Total Visits], 
REMOVEFILTERS(DimDate), DimDate[Date] = Ref)

--30.  Period END
Period End Date = [Reference Date]

--31.  Period START
Period Start Date = 
VAR Sel = SELECTEDVALUE(PeriodPicker[PeriodName], "Month") 
VAR Ref = [Reference Date] RETURN SWITCH(Sel, "Today", Ref, 
      "Week", Ref - 6, 
      "Month", DATE(YEAR(Ref), MONTH(Ref), 1), 
      "Quarter", DATE(YEAR(Ref), ((MONTH(Ref) - 1) - MOD(MONTH(Ref) - 1, 3)) + 1, 1),
      "Year",    DATE(YEAR(Ref), 1, 1),   Ref)

--32.  Previous Week Volume
Previous Week Patient Volume = 
VAR Ref = [Reference Date] 
VAR PrevEnd = Ref - 7 
VAR PrevStart = Ref - 13 
RETURN CALCULATE([Total Visits], 
REMOVEFILTERS(DimDate),   DimDate[Date] >= PrevStart && DimDate[Date] <= PrevEnd)

--33.  Reference Date
Reference Date = CALCULATE(MAX(DimDate[Date]), ALL(DimDate))

--34.  Week-on Week change in a group
Region Flow Delta = [Region Visits Week] - [Region Visits Prev Week]

--35.  Status of week-on-week change
Region Flow Status = VAR D = [Region Flow Delta] 
RETURN SWITCH(TRUE(), D > 5, "Increased Flow",  D < -5, "Decreased Flow",   "Stable")

--36. Prev week volume in a category
Region Visits Prev Week = 
VAR Ref = [Reference Date] 
VAR PrevEnd = Ref - 7 
VAR PrevStart = Ref - 13 
RETURN CALCULATE([Total Visits], 
REMOVEFILTERS(DimDate),   DimDate[Date] >= PrevStart && DimDate[Date] <= PrevEnd)

--37.  Volume in a week
Region Visits Week = 
VAR Ref = [Reference Date] 
VAR WeekStart = Ref - 6 
RETURN CALCULATE([Total Visits], 
REMOVEFILTERS(DimDate),   DimDate[Date] >= WeekStart && DimDate[Date] <= Ref)

--38.  Satisfacation %
Satisfaction Pct = DIVIDE([Avg Satisfaction], 100)

--39.  Satifaction % in a specific period
Satisfaction Pct Period = 
VAR S = [Period Start Date] 
VAR E = [Period End Date] 
RETURN CALCULATE([Satisfaction Pct], 
REMOVEFILTERS(DimDate), DimDate[Date] >= S && DimDate[Date] <= E)

--40  % Prev Period
Satisfaction Pct Period = 
VAR S = [Period Start Date] 
VAR E = [Period End Date] 
RETURN CALCULATE([Satisfaction Pct], 
REMOVEFILTERS(DimDate), DimDate[Date] >= S && DimDate[Date] <= E)

--41.  % in specific month
Satisfaction Selected Month = 
VAR Sel = SELECTEDVALUE(MonthPicker[YearMonth]) 
RETURN CALCULATE([Satisfaction Pct], 
REMOVEFILTERS(DimDate), DimDate[YearMonth] = Sel)

--42.   Satisfaction % vs Target
Satisfaction vs Target = [Satisfaction Pct Period] - [Target Satisfaction]

--43. Dynamic Name of Selected KPI
Selected KPI Name = SELECTEDVALUE(KPISelector[KPIName], "Patient Volume")

--44. Total Count of People
Staff Count = SUM(FactStaffing[StaffCount])

--45.  Performance rate all time- assumed more is better
Staff Efficiency = DIVIDE([Patients Handled], [Staff Count])

--46.  Performance rate specific period  
Staff Efficiency Period = 
VAR S = [Period Start Date] 
VAR E = [Period End Date] R
ETURN CALCULATE([Staff Efficiency], 
REMOVEFILTERS(DimDate), DimDate[Date] >= S && DimDate[Date] <= E)

--47.  Performance in selected month
Staff Efficiency Selected Month = 
VAR Sel = SELECTEDVALUE(MonthPicker[YearMonth]) 
RETURN CALCULATE([Staff Efficiency], 
REMOVEFILTERS(DimDate), DimDate[YearMonth] = Sel)

--48.  Performance vs previous Quarter
Staff Efficiency vs Last Quarter = 
VAR Ref = [Reference Date] 
VAR Cur = CALCULATE([Staff Efficiency], 
REMOVEFILTERS(DimDate),   DimDate[Date] >= DATE(YEAR(Ref), MONTH(Ref) - 2, 1) && DimDate[Date] <= Ref) VAR Prev = CALCULATE([Staff Efficiency], 
REMOVEFILTERS(DimDate),   DimDate[Date] >= DATE(YEAR(Ref), MONTH(Ref) - 5, 1) &&   DimDate[Date] <= DATE(YEAR(Ref), MONTH(Ref) - 3, 1)) 
RETURN Cur - Prev

--49.  Staffing %
Staffing Level Pct = 
VAR Ratio = [Staff Efficiency] 
VAR Target = [Target Staff Efficiency] 
RETURN DIVIDE(Ratio, Target)

--50. Target Rate
Target Bed Occupancy = 0.80

--51.  Target time
Target Emergency Wait = 20

--52.  Target rate again
Target Satisfaction = 0.91

-- 53.  Target rate
Target Staff Efficiency = 4.7

-- 54.  Target rate
Target Treatment Success = 0.93

-- 55.  Target
Target Wait Minutes = 15

--56.  Total 1
Total Beds = SUM(FactBedOccupancy[BedsTotal])

--57.  Total 2
Total Visits = COUNTROWS(FactPatientVisit)

--58.  Success rate
Treatment Success Rate = 
DIVIDE(CALCULATE(COUNTROWS(FactPatientVisit), FactPatientVisit[TreatmentSuccess] = 1), 
COUNTROWS(FactPatientVisit))

--59.  Success rate specific period
Treatment Success Rate Period = 
VAR S = [Period Start Date] 
VAR E = [Period End Date] 
RETURN CALCULATE([Treatment Success Rate], 
REMOVEFILTERS(DimDate), DimDate[Date] >= S && DimDate[Date] <= E)

--60.  Success v last year (problem here)
Treatment Success vs Last Year = 
VAR Ref = [Reference Date] 
VAR Cur = CALCULATE([Treatment Success Rate], 
REMOVEFILTERS(DimDate),   DimDate[Year] = YEAR(Ref)) 
VAR Prev = CALCULATE([Treatment Success Rate], 
REMOVEFILTERS(DimDate),   DimDate[Year] = YEAR(Ref) - 1) RETURN Cur - Prev

--61.  Trend current month
Trend Current Month = 
VAR SelKPI = [Selected KPI Name] 
VAR Ref = [Reference Date] 
VAR CurYear = YEAR(Ref) 
VAR CurMonth = MONTH(Ref) 
VAR Dom = SELECTEDVALUE(DimDate[DayOfMonth]) 
VAR LastDay = DAY(EOMONTH(DATE(CurYear, CurMonth, 1), 0)) 
VAR TargetDate = IF(Dom <= LastDay, DATE(CurYear, CurMonth, Dom)) 
RETURN CALCULATE( SWITCH(SelKPI, "Patient Volume", [Total Visits], "Bed Occupancy", [Bed Occupancy Rate],
            "Satisfaction", [Satisfaction Pct], "Staff Efficiency", [Staff Efficiency], 
            "Emergency Wait", [Emergency Wait Time]), 
            ALL(DimDate), DimDate[Date] = TargetDate)

--62.  Trend Prev Month
Trend Previous Month = 
VAR SelKPI = [Selected KPI Name] 
VAR Ref = [Reference Date] 
VAR PrevEnd = EOMONTH(Ref, -1) 
VAR PrevYear = YEAR(PrevEnd) 
VAR PrevMonth = MONTH(PrevEnd) 
VAR Dom = SELECTEDVALUE(DimDate[DayOfMonth]) 
VAR LastDay = DAY(PrevEnd) VAR TargetDate = IF(Dom <= LastDay, DATE(PrevYear, PrevMonth, Dom)) 
RETURN CALCULATE(  SWITCH(SelKPI, "Patient Volume", [Total Visits], "Bed Occupancy", [Bed Occupancy Rate],
            "Satisfaction", [Satisfaction Pct], "Staff Efficiency", [Staff Efficiency], 
            "Emergency Wait", [Emergency Wait Time]),   
            ALL(DimDate),   DimDate[Date] = TargetDate)

--63.  Events Last 7 days
Visits Last 7 Days = 
VAR Ref = [Reference Date] 
VAR WeekStart = Ref - 6 
VAR RowDate = MAX(DimDate[Date]) 
RETURN IF(RowDate >= WeekStart && RowDate <= Ref, [Total Visits])

--64.  Events this period
Visits Period = 
VAR S = [Period Start Date] 
VAR E = [Period End Date] 
RETURN CALCULATE([Total Visits], 
REMOVEFILTERS(DimDate), DimDate[Date] >= S && DimDate[Date] <= E)

--65.  Events Prev 7 days
Visits Prev 7 Days = 
VAR Ref = [Reference Date] 
VAR PrevEnd = Ref - 7 
VAR PrevStart = Ref - 13 
VAR RowDate = MAX(DimDate[Date]) - 7 
RETURN IF(RowDate >= PrevStart && RowDate <= PrevEnd,   
CALCULATE([Total Visits], REMOVEFILTERS(DimDate), DimDate[Date] = RowDate))

--66.  Down Time vs Last month
Wait Time vs Last Month = 
VAR Ref = [Reference Date] 
VAR CurStart = DATE(YEAR(Ref), MONTH(Ref), 1) 
VAR PrevEnd = CurStart - 1 
VAR PrevStart = DATE(YEAR(PrevEnd), MONTH(PrevEnd), 1) 
VAR Cur = CALCULATE([Avg Wait Time], 
REMOVEFILTERS(DimDate), DimDate[Date] >= CurStart && DimDate[Date] <= Ref) 
VAR Prev = CALCULATE([Avg Wait Time], 
REMOVEFILTERS(DimDate),   DimDate[Date] >= PrevStart && DimDate[Date] <= PrevEnd) RETURN Cur - Prev

--  67.  Weekly events
Weekly Patient Volume = 
VAR Ref = [Reference Date] 
VAR WeekStart = Ref - 6 
RETURN CALCULATE([Total Visits], 
REMOVEFILTERS(DimDate),   DimDate[Date] >= WeekStart && DimDate[Date] <= Ref)

--68.  Weekly event delta
Weekly Volume Delta = [Weekly Patient Volume] - [Previous Week Patient Volume]
